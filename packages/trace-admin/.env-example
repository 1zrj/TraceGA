# TraceGA Admin — 环境变量模板
# 复制此文件为 .env（被 .gitignore 忽略）后填写自定义值
# 或直接使用 .env.development / .env.production（会提交到 Git）

# API 地址
# 开发环境通过 Vite proxy 转发，填 /api 即可
# 生产环境可配置完整 URL，如 https://api.example.com
VITE_API_BASE_URL=/api

# Mock 开关
# true  — 启用 MSW Mock，前端独立运行
# false — 关闭 Mock，连接真实后端
VITE_ENABLE_MOCK=true

# 应用标题
VITE_APP_TITLE=TraceGA Admin
